ANTHROPIC_API_KEY=your_key_here
RAGAS_APP_TOKEN=optional_ragas_cloud_token
CORS_ORIGINS=http://localhost:3000

# LLM configuration (optional — defaults shown)
ANTHROPIC_MODEL=claude-sonnet-4-6
MAX_TOKENS_HALLUCINATION=1024
MAX_TOKENS_EXPLANATION=256
MAX_TOKENS_GENERATION=4096
LLM_MAX_RETRIES=2
LLM_TIMEOUT=60.0
